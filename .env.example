# Copie pra .env e preencha. Nunca commitar o .env (gitignored).

# --- Auth ----------------------------------------------------------
# Conta de admin (login user+senha). Cria/edita atribuições email→time.
ADMIN_USER=admin
ADMIN_PASS=

# Google OAuth — pegue no console.cloud.google.com:
# APIs & Services → Credentials → Create credentials → OAuth client ID
# Application type: Web application.
# Authorized redirect URIs: http://localhost:8080/api/auth/google/callback
# (e a URL de produção em seguida)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# --- Cartola / fotos ----------------------------------------------
# API-Football (api-sports.io) — fallback histórico, hoje usamos ogol+rembg
# Cadastro: https://dashboard.api-football.com/register
# Chave: https://dashboard.api-football.com/profile/?access
API_FOOTBALL_KEY=
